{
  "name": "applr",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rsbuild build",
    "dev": "rsbuild --open",
    "format": "prettier --write .",
    "lint": "rslint",
    "preview": "rsbuild preview",
    "test": "rstest",
    "test:watch": "rstest --watch",
    "prepare": "node -e \"const { execSync } = require('node:child_process'); if (process.env.NODE_ENV !== 'production' && process.env.CI !== 'true') execSync('husky .husky', { stdio: 'inherit', shell: true });\""
  },
  "dependencies": {
    "vue": "3.5.34"
  },
  "devDependencies": {
    "@rsbuild/core": "2.0.7",
    "@rsbuild/plugin-vue": "1.2.8",
    "@rslint/core": "0.5.1",
    "@rstest/adapter-rsbuild": "0.10.2",
    "@rstest/core": "0.10.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/vue": "8.1.0",
    "happy-dom": "20.9.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.3",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=24.13.0",
    "pnpm": ">=10.28.0"
  }
}
